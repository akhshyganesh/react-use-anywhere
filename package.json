{
  "name": "react-hook-injection-pattern",
  "version": "1.0.0",
  "description": "A production-ready React library for safely using React hooks in non-React files through dependency injection pattern",
  "author": "akhshyganesh <akhshy.balakannan@gmail.com>",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "REACT_COMPATIBILITY.md"
  ],
  "keywords": [
    "react",
    "hooks",
    "dependency-injection",
    "navigation",
    "service",
    "pattern",
    "typescript",
    "react-router"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/akhshyganesh/react-hook-injection-pattern.git"
  },
  "bugs": {
    "url": "https://github.com/akhshyganesh/react-hook-injection-pattern/issues"
  },
  "homepage": "https://github.com/akhshyganesh/react-hook-injection-pattern#readme",
  "scripts": {
    "dev": "vite --config vite.demo.config.ts",
    "build": "npm run build:lib && npm run build:demo",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:demo": "vite build --config vite.demo.config.ts",
    "preview": "vite preview --config vite.demo.config.ts",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "type-check": "tsc --noEmit",
    "prepublishOnly": "npm run lint && npm run test && npm run build:lib"
  },
  "peerDependencies": {
    "react": ">=16.8.0 <19.0.0-0",
    "react-dom": ">=16.8.0 <19.0.0-0"
  },
  "peerDependenciesMeta": {
    "react-router-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^29.5.12",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "ts-jest": "^29.4.0",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vite-plugin-dts": "^3.7.2"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "jsdom",
    "setupFilesAfterEnv": ["<rootDir>/test/setup.ts"],
    "testMatch": [
      "<rootDir>/test/**/*.{test,spec}.{ts,tsx}"
    ],
    "moduleNameMapping": {
      "^@/(.*)$": "<rootDir>/lib/$1"
    }
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  }
}
