{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./lib",
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "noEmit": false,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  },
  "include": [
    "lib/**/*"
  ],
  "exclude": [
    "demo/**/*",
    "examples/**/*",
    "**/*.test.*",
    "**/*.spec.*",
    "node_modules"
  ]
}
